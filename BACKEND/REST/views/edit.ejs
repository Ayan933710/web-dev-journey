<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Posts</title>
  </head>
  <body>
    <h2>Edit your Post</h2>
    <h3>Post id : <%= post.id %></h3>
    <h3>Post username : @<%= post.username %></h3>
    <!-- using method-override to send DELETE request instead of POST request from html form -->
    <form method="POST" action="/posts/<%= post.id %>?_method=PATCH">
      <textarea rows="10" cols="35" name="content">
            <%= post.content %>
        </textarea
      >
      <br />
      <br />
      <button>Update Post</button>
    </form>
  </body>
</html>
