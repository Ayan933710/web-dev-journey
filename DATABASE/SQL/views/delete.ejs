<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delete Users</title>
  </head>
  <body>
    <h3>Delete User : <%= targetuser.email %></h3>
    <form method="POST" action="/user/<%= targetuser.id %>?_method=DELETE">
      <input
        type="text"
        name="username"
        placeholder="<%= targetuser.username %>"
      />
      <br />
      <br />
      <input
        type="password"
        name="password"
        placeholder="Enter your password"
      />
      <br />
      <br />
      <button>Delete User</button>
    </form>
  </body>
</html>
