<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All Users</title>
    <style>
      table,
      tr,
      td {
        border: 1px solid black;
      }
    </style>
  </head>
  <body>
    <h3>All Listed Users</h3>
    <br />
     <form method="GET" action="/user/add">
            <button>Add New User</button>
        </form>
        <br />
    <table>
      <tr>
        <th>Id</th>
        <th>Email</th>
        <th>Username</th>
      </tr>
      <% for ( user of users) { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.email %></td>
        <td><%= user.username %></td>
        <td>
        <form method="GET" action="/user/<%= user.id %>/edit">
            <button>Edit Username</button>
        </form>
        </td>
         <td>
        <form method="GET" action="/user/<%= user.id %>/delete">
            <button>Delete User</button>
        </form>
        </td>
      </tr>
      <% } %>
    </table>
  </body>
</html>
