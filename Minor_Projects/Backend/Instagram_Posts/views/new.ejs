<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Creating New Post</title>
  </head>
  <body>
    <h2>Create a New Instagram Post</h2>
    <form method="post" action="/ig/posts">
      <input placeholder="enter your username" name="username" type="text" />
      <br />
      <br />
      <input placeholder="Enter image url" name="photo" type="text" />
      <br />
      <br />
      <input placeholder="Enter the content..." name="content" type="text" />
      <br />
      <br />
      <button>Create Post</button>
    </form>
  </body>
</html>
