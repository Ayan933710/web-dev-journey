<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Whatsapp Chats</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <h3>All Chats</h3>
    <form method="GET" action="/chats/new">
      <button>New Chat</button>
    </form>
    <br />
    <% for(let chat of chats) { %>
        <div class="chats">
            <p>From : <i> <%= chat.from %></i></p>
            <div class="message">
                <p><%= chat.msg %></p>
                <div class="msg-func">
                  <form method="GET" action="/chats/<%= chat._id %>">
                  <button>Show</button>
                </form>
                &nbsp;
                <form method="GET" action="/chats/<%= chat._id %>/edit">
                  <button>Edit</button>
                </form>
                &nbsp;
                <form method="POST" action="/chats/<%= chat._id %>?_method=DELETE">
                  <button>Delete</button>
                </form>
                </div>
            </div>
            <p>Received by <i> <%= chat.to %></i></p>
            <hr />
            <p><%= chat.created_at.toString().split(" ")[4] %></p>
            <p><%= chat.created_at.toString().split(" ").slice(0, 4).join("-") %></p>
        </div>
        <br /><br />
    <% } %>
  </body>
</html>
